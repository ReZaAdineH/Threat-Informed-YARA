## Credential access
-w /etc/shadow -p r -k mc_credential_access
-w /etc/gshadow -p r -k mc_credential_access
-w /etc/security/opasswd -p r -k mc_credential_access
-w /root/.ssh/ -p r -k mc_credential_access_ssh
-w /etc/krb5.conf -p r -k mc_credential_access_kerberos
-w /etc/krb5.keytab -p r -k mc_credential_access_kerberos
-w /var/lib/sss/ -p r -k mc_credential_access_sssd
-w /etc/sssd/ -p r -k mc_credential_access_sssd

-w /usr/bin/gcore -p x -k mc_process_dump
-w /usr/bin/gdb -p x -k mc_debugger
-w /usr/bin/strace -p x -k mc_debugger
-w /usr/bin/ltrace -p x -k mc_debugger
