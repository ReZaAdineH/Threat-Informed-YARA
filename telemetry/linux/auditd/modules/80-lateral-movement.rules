## Lateral movement and remote access tooling
-w /usr/bin/ssh -p x -k mc_lateral_movement
-w /usr/bin/scp -p x -k mc_lateral_movement
-w /usr/bin/sftp -p x -k mc_lateral_movement
-w /usr/bin/rsync -p x -k mc_lateral_movement
-w /usr/bin/nc -p x -k mc_lateral_movement
-w /bin/nc -p x -k mc_lateral_movement
-w /usr/bin/ncat -p x -k mc_lateral_movement
-w /usr/bin/socat -p x -k mc_lateral_movement
-w /usr/bin/telnet -p x -k mc_lateral_movement
-w /usr/bin/rdesktop -p x -k mc_lateral_movement
-w /usr/bin/xfreerdp -p x -k mc_lateral_movement
