## Privilege escalation and sensitive permission changes
-w /usr/bin/sudo -p x -k mc_privilege_escalation
-w /bin/su -p x -k mc_privilege_escalation
-w /usr/bin/su -p x -k mc_privilege_escalation
-w /usr/bin/pkexec -p x -k mc_privilege_escalation

-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=4294967295 -k mc_permission_change
-a always,exit -F arch=b32 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=4294967295 -k mc_permission_change
-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=4294967295 -k mc_owner_change
-a always,exit -F arch=b32 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=4294967295 -k mc_owner_change

-a always,exit -F arch=b64 -S setxattr,lsetxattr,fsetxattr,removexattr,lremovexattr,fremovexattr -k mc_extended_attribute_change
-a always,exit -F arch=b32 -S setxattr,lsetxattr,fsetxattr,removexattr,lremovexattr,fremovexattr -k mc_extended_attribute_change
