## Persistence: cron, systemd, startup profiles, SSH keys
-w /etc/crontab -p wa -k mc_persistence_cron
-w /etc/cron.d/ -p wa -k mc_persistence_cron
-w /etc/cron.daily/ -p wa -k mc_persistence_cron
-w /etc/cron.hourly/ -p wa -k mc_persistence_cron
-w /etc/cron.monthly/ -p wa -k mc_persistence_cron
-w /etc/cron.weekly/ -p wa -k mc_persistence_cron
-w /var/spool/cron/ -p wa -k mc_persistence_cron
-w /var/spool/cron/crontabs/ -p wa -k mc_persistence_cron

-w /etc/systemd/system/ -p wa -k mc_persistence_systemd
-w /usr/lib/systemd/system/ -p wa -k mc_persistence_systemd
-w /lib/systemd/system/ -p wa -k mc_persistence_systemd
-w /etc/init.d/ -p wa -k mc_persistence_init

-w /etc/rc.local -p wa -k mc_persistence_startup
-w /etc/profile -p wa -k mc_persistence_shell_profile
-w /etc/profile.d/ -p wa -k mc_persistence_shell_profile
-w /etc/bash.bashrc -p wa -k mc_persistence_shell_profile
-w /root/.bashrc -p wa -k mc_persistence_shell_profile
-w /root/.profile -p wa -k mc_persistence_shell_profile

-w /root/.ssh/ -p wa -k mc_persistence_ssh
-w /etc/ssh/sshd_config -p wa -k mc_ssh_config
-w /etc/ssh/ssh_config -p wa -k mc_ssh_config
